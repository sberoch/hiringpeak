{
  "name": "@workspace/shared",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "default": "./dist/enums.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./schemas": {
      "types": "./dist/schemas/schema.d.ts",
      "default": "./dist/schemas/schema.js"
    },
    "./dtos": {
      "types": "./dist/dtos/index.d.ts",
      "default": "./dist/dtos/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "latest"
  }
}