# Copy this file to .env.production and fill in real values.
# Used by docker compose via: --env-file infra/docker/.env.production

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=hiringpeak

# --- API runtime ---
# Internal URL (service DNS within the compose network)
DATABASE_URL=postgresql://postgres:replace-with-a-strong-password@postgres:5432/hiringpeak
JWT_SECRET=replace-with-a-long-random-secret

# Public URLs (used for CORS allow-list and next-auth AUTH_URL values)
FRONTEND_URL=https://app.hiringpeak.com
BACKOFFICE_URL=https://backoffice.hiringpeak.com
LANDING_URL=https://hiringpeak.com

# Optional
GOOGLE_CLIENT_ID=

# --- Web (build-time, baked into the bundle) ---
# Must be the publicly reachable API URL including the /api/v1 prefix
NEXT_PUBLIC_API_URL=https://api.hiringpeak.com/api/v1
NEXT_PUBLIC_LOGIN_ENABLED=true
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED=true

NEXT_PUBLIC_FIREBASE_API_KEY=replace
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace
NEXT_PUBLIC_FIREBASE_APP_ID=replace
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SPREADSHEET_URL=

# --- Web / Backoffice (next-auth runtime) ---
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Host port bindings (all services bind to 127.0.0.1 by default) ---
API_BIND_IP=127.0.0.1
API_PORT=5003
WEB_BIND_IP=127.0.0.1
WEB_PORT=5000
BACKOFFICE_BIND_IP=127.0.0.1
BACKOFFICE_PORT=5002
LANDING_BIND_IP=127.0.0.1
LANDING_PORT=5001
